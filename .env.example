# Root Docker Compose environment for local development.
# Copy this file to .env when you want to override local defaults.

AUTH_APP_KEY=
INVENTORY_APP_KEY=
ORDER_APP_KEY=
JWT_ISSUER=flash-sale-auth
JWT_SECRET=flash-sale-demo-jwt-secret
GATEWAY_USER_ID_HEADER=X-Internal-User-Id

KONG_AUTH_SERVICE_URL=http://auth-service:8000/api
KONG_INVENTORY_SERVICE_URL=http://inventory-service:8000/api
KONG_ORDER_SERVICE_URL=http://order-service:8000/api
